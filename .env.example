# ===================================
# Task Vision — Variáveis de Ambiente
# ===================================
# Copie este arquivo para .env e preencha os valores
#
# cp .env.example .env
#
# NUNCA commite o .env no Git!

# Conexão com o PostgreSQL (Railway gera automaticamente)
DATABASE_URL=

# Chave secreta para assinar tokens JWT (gere com: openssl rand -base64 32)
JWT_SECRET=

# Admin padrão — criado automaticamente no primeiro seed
DEFAULT_ADMIN_EMAIL=admin@taskvision.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Administrador
