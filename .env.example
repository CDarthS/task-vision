# NextAuth.js (Fase 2 — Autenticação)
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# Login com Google (Fase 2 — Autenticação)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
