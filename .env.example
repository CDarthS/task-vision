# ===================================
# Task Vision — Variáveis de Ambiente
# ===================================
# Copie este arquivo para .env e preencha os valores
#
# cp .env.example .env
#
# NUNCA commite o .env no Git!

# Conexão com o PostgreSQL (Railway gera automaticamente)
DATABASE_URL=

# Chave secreta para assinar tokens JWT (gere com: openssl rand -base64 32)
JWT_SECRET=

# Admin padrão — criado automaticamente no primeiro seed
DEFAULT_ADMIN_EMAIL=admin@taskvision.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Administrador

# Redis — Filas assincronas (BullMQ)
# Se nao configurar, o sistema usa processamento sincrono (fallback)
REDIS_URL=

# Railway Bucket (Object Storage S3-compatible)
# Criado via Railway Dashboard > + Add > Bucket
# Use "Add to Service" para injetar automaticamente no servico task-vision
AWS_ENDPOINT_URL=
AWS_S3_BUCKET_NAME=
AWS_DEFAULT_REGION=auto
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
